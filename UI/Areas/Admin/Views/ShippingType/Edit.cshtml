@model BL.DTOs.ShippingType.UpdateShippingTypeDto
@{
    ViewData["Title"] = "Edit Shipping Type";
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Edit Shipping Type </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="ShippingType" asp-action="Index">Shipping Types</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4"><i class="mdi mdi-truck-fast me-2"></i>Edit Shipping Type Details</h4>
                    <form id="editForm" class="forms-sample" asp-controller="ShippingType" asp-action="Save" asp-route-id="@ViewBag.Id" method="post">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" name="id" value="@ViewBag.Id" />

                        <div class="form-group mb-3">
                            <label asp-for="ShippingTypeAname">Arabic Name</label>
                            <input asp-for="ShippingTypeAname" type="text" class="form-control" placeholder="Enter Arabic Name (e.g. سريع)" required />
                            <span asp-validation-for="ShippingTypeAname" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ShippingTypeEname">English Name</label>
                            <input asp-for="ShippingTypeEname" type="text" class="form-control" placeholder="Enter English Name (e.g. Express)" required />
                            <span asp-validation-for="ShippingTypeEname" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ShippingFactor">Shipping Factor</label>
                            <input asp-for="ShippingFactor" type="number" step="0.01" min="0" class="form-control" placeholder="Enter Factor (e.g. 1.50)" required />
                            <span asp-validation-for="ShippingFactor" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="button" id="saveBtn" class="btn btn-gradient-primary me-2">
                                <i class="mdi mdi-content-save me-1"></i> Save
                            </button>
                            <a asp-controller="ShippingType" asp-action="Index" class="btn btn-light">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.getElementById('saveBtn').addEventListener('click', function () {
            var form = document.getElementById('editForm');

            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: "Do you want to save the changes?",
                showDenyButton: true,
                showCancelButton: true,
                confirmButtonText: "Save",
                denyButtonText: "Don't save",
                icon: "question"
            }).then((result) => {
                if (result.isConfirmed) {

                    // ✅ Swal Loading لثانيتين
                    Swal.fire({
                        title: "Saving...",
                        text: "Please wait",
                        icon: "success",
                        timer: 2000,
                        showConfirmButton: false,
                        allowOutsideClick: false
                    });

                    // ✅ بعد ثانيتين يعمل Submit
                    setTimeout(function () {
                        form.submit();
                    }, 2000);

                } else if (result.isDenied) {
                    Swal.fire("Changes are not saved", "", "info");
                }
            });
        });
    </script>
}