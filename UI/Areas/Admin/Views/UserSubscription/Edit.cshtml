@model BL.DTOs.UserSubscription.UpdateUserSubscriptionDto
@{
    ViewData["Title"] = "Edit User Subscription";
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Edit User Subscription </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="UserSubscription" asp-action="Index">User Subscriptions</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>
    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <form class="forms-sample" asp-controller="UserSubscription" asp-action="Edit" asp-route-id="@ViewBag.Id" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-group mb-4">
                            <label asp-for="PackageId">Package</label>
                            <select asp-for="PackageId" class="form-control" asp-items="ViewBag.Packages">
                                <option value="">-- Select Package --</option>
                            </select>
                            <span asp-validation-for="PackageId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="UserId">User</label>
                            <select asp-for="UserId" class="form-control" asp-items="ViewBag.Users">
                                <option value="">-- Select User --</option>
                            </select>
                            <span asp-validation-for="UserId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="SubscriptionDate">Subscription Date</label>
                            <input asp-for="SubscriptionDate" type="date" class="form-control" />
                            <span asp-validation-for="SubscriptionDate" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-gradient-primary me-2">Save</button>
                            <a asp-controller="UserSubscription" asp-action="Index" class="btn btn-light">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
