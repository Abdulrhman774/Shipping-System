@model BL.DTOs.SubscriptionPackage.CreateSubscriptionPackageDto
@{
    ViewData["Title"] = "Add Subscription Package";
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Add Subscription Package </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="SubscriptionPackage" asp-action="Index">Subscription Packages</a></li>
                <li class="breadcrumb-item active" aria-current="page">Add</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4"><i class="mdi mdi-package-variant-closed me-2"></i>Package Details</h4>
                    
                    <form class="forms-sample" asp-controller="SubscriptionPackage" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-group mb-3">
                            <label asp-for="PackageName">Package Name</label>
                            <input asp-for="PackageName" type="text" class="form-control" placeholder="Enter Package Name (e.g. Premium Package)" required />
                            <span asp-validation-for="PackageName" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ShipimentCount">Shipment Count Limit</label>
                            <input asp-for="ShipimentCount" type="number" min="1" class="form-control" placeholder="Enter Maximum Shipments Allowed" required />
                            <span asp-validation-for="ShipimentCount" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="NumberOfKiloMeters">Kilometers Limit (KM)</label>
                            <input asp-for="NumberOfKiloMeters" type="number" step="0.1" min="0" class="form-control" placeholder="Enter Maximum Kilometers Allowed" required />
                            <span asp-validation-for="NumberOfKiloMeters" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="TotalWeight">Total Weight Limit (kg)</label>
                            <input asp-for="TotalWeight" type="number" step="0.1" min="0" class="form-control" placeholder="Enter Maximum Weight Allowed" required />
                            <span asp-validation-for="TotalWeight" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-gradient-primary me-2">
                                <i class="mdi mdi-content-save me-1"></i> Save
                            </button>
                            <a asp-controller="SubscriptionPackage" asp-action="Index" class="btn btn-light">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
