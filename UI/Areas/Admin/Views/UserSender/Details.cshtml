@model Domain.Entities.TbUserSender
@{
    ViewData["Title"] = "Sender Details";
    var shipments = ViewBag.Shipments as List<dynamic>;
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Sender Details </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="UserSender" asp-action="Index">Senders</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <!-- Sender Info Card -->
        <div class="col-md-5 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <div class="text-center pb-4 border-bottom">
                        <i class="mdi mdi-account-circle text-primary display-1 mb-3"></i>
                        <h4 class="card-title mb-1">@Model.SenderName</h4>
                        <p class="text-muted mb-0 small">User ID: @Model.UserId</p>
                        <div class="mt-3">
                            @if (Model.CurrentState == enEntityState.Active)
                            {
                                <span class="badge badge-gradient-success">Active</span>
                            }
                            else if (Model.CurrentState == enEntityState.Inactive)
                            {
                                <span class="badge badge-gradient-warning">Inactive</span>
                            }
                            else if (Model.CurrentState == enEntityState.Deleted)
                            {
                                <span class="badge badge-gradient-danger">Deleted</span>
                            }
                        </div>
                    </div>
                    <div class="py-4">
                        <div class="d-flex justify-content-between mb-3">
                            <span class="font-weight-bold text-dark">Email:</span>
                            <span class="text-muted">@Model.Email</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="font-weight-bold text-dark">Phone:</span>
                            <span class="text-muted">@Model.Phone</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="font-weight-bold text-dark">City:</span>
                            <span class="text-muted">@(Model.City?.CityEname ?? "N/A")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="font-weight-bold text-dark">Registered Date:</span>
                            <span class="text-muted">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                        <div class="mt-4">
                            <span class="d-block font-weight-bold text-dark mb-2">Address:</span>
                            <span class="d-block text-muted bg-light p-3 rounded" style="white-space: pre-line; line-height: 1.5;">@Model.Address</span>
                        </div>
                    </div>
                    <div class="mt-3 text-center d-flex flex-column gap-2">
                        <a asp-controller="UserSender" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-gradient-info btn-fw">
                            <i class="mdi mdi-pencil me-1"></i> Edit Profile
                        </a>
                        <a asp-controller="UserSender" asp-action="Index" class="btn btn-light btn-fw">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Shipments History Card -->
        <div class="col-md-7 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4"><i class="mdi mdi-history me-2"></i>Shipments Sent</h4>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th> Code </th>
                                    <th> Receiver </th>
                                    <th> Date </th>
                                    <th> Type </th>
                                    <th> Weight </th>
                                    <th> Status </th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (shipments != null && shipments.Any())
                                {
                                    foreach (var shp in shipments)
                                    {
                                        <tr>
                                            <td class="font-weight-bold">@shp.Code</td>
                                            <td>@shp.Receiver</td>
                                            <td>@shp.Date.ToString("yyyy-MM-dd")</td>
                                            <td>@shp.Type</td>
                                            <td>@shp.Weight.ToString("0.0") kg</td>
                                            <td>
                                                @if (shp.Status == "Delivered")
                                                {
                                                    <span class="badge badge-gradient-success">Delivered</span>
                                                }
                                                else if (shp.Status == "In Transit")
                                                {
                                                    <span class="badge badge-gradient-info">In Transit</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-gradient-warning">Pending</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No shipments found for this sender.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
