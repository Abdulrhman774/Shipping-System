@model BL.DTOs.Country.CreateCountryDto
@{
    ViewData["Title"] = "Add Country";
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Add Country </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="Country" asp-action="Index">Countries</a></li>
                <li class="breadcrumb-item active" aria-current="page">Add</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4"><i class="mdi mdi-earth me-2"></i>Country Details</h4>
                    
                    <form class="forms-sample" asp-controller="Country" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-group mb-3">
                            <label asp-for="CountryAname">Arabic Name</label>
                            <input asp-for="CountryAname" type="text" class="form-control" placeholder="Enter Arabic Name (e.g. مصر)" required />
                            <span asp-validation-for="CountryAname" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="CountryEname">English Name</label>
                            <input asp-for="CountryEname" type="text" class="form-control" placeholder="Enter English Name (e.g. Egypt)" required />
                            <span asp-validation-for="CountryEname" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-gradient-primary me-2">
                                <i class="mdi mdi-content-save me-1"></i> Save
                            </button>
                            <a asp-controller="Country" asp-action="Index" class="btn btn-light">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
