@model BL.DTOs.Shipment.CreateShipmentDto
@{
    ViewData["Title"] = "Create Shipment";
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Create Shipment </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shipment" asp-action="Index">Shipments</a></li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <div class="col-12 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <form class="forms-sample" asp-controller="Shipment" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Section 1: Shipment Info -->
                        <h4 class="card-title text-primary mb-3 border-bottom pb-2">
                            <i class="mdi mdi-information-outline me-2"></i>1. Shipment Info
                        </h4>
                        <div class="row mb-4">
                            <div class="col-md-4 form-group">
                                <label asp-for="ShippingDate">Shipping Date</label>
                                <input asp-for="ShippingDate" type="date" class="form-control" required />
                                <span asp-validation-for="ShippingDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 form-group">
                                <label asp-for="ShippingTypeId">Shipping Type</label>
                                <select asp-for="ShippingTypeId" class="form-control form-select" asp-items="ViewBag.ShippingTypes" required>
                                    <option value="">Select Type</option>
                                </select>
                                <span asp-validation-for="ShippingTypeId" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 form-group">
                                <label asp-for="PaymentMethodId">Payment Method</label>
                                <select asp-for="PaymentMethodId" class="form-control form-select" asp-items="ViewBag.PaymentMethods">
                                    <option value="">Select Method (Optional)</option>
                                </select>
                                <span asp-validation-for="PaymentMethodId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Section 2: Package Dimensions -->
                        <h4 class="card-title text-primary mb-3 border-bottom pb-2">
                            <i class="mdi mdi-package-variant me-2"></i>2. Package Details
                        </h4>
                        <div class="row mb-4">
                            <div class="col-md-3 form-group">
                                <label asp-for="Weight">Weight (kg)</label>
                                <input asp-for="Weight" type="number" step="0.1" class="form-control package-calc" placeholder="0.0" required />
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>
                            <div class="col-md-3 form-group">
                                <label asp-for="Length">Length (cm)</label>
                                <input asp-for="Length" type="number" step="0.1" class="form-control" placeholder="0.0" required />
                                <span asp-validation-for="Length" class="text-danger"></span>
                            </div>
                            <div class="col-md-3 form-group">
                                <label asp-for="Width">Width (cm)</label>
                                <input asp-for="Width" type="number" step="0.1" class="form-control" placeholder="0.0" required />
                                <span asp-validation-for="Width" class="text-danger"></span>
                            </div>
                            <div class="col-md-3 form-group">
                                <label asp-for="Height">Height (cm)</label>
                                <input asp-for="Height" type="number" step="0.1" class="form-control" placeholder="0.0" required />
                                <span asp-validation-for="Height" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 form-group mt-2">
                                <label asp-for="PackageValue">Declared Value ($)</label>
                                <input asp-for="PackageValue" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                <span asp-validation-for="PackageValue" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 form-group mt-2">
                                <label asp-for="ShippingRate">Estimated Rate ($) - Calculated</label>
                                <input asp-for="ShippingRate" type="text" class="form-control bg-light" id="ShippingRate" value="0.00" readonly />
                            </div>
                        </div>

                        <!-- Section 3: Sender & Receiver -->
                        <h4 class="card-title text-primary mb-3 border-bottom pb-2">
                            <i class="mdi mdi-account-multiple me-2"></i>3. Sender & Receiver
                        </h4>
                        <div class="row mb-4">
                            <div class="col-md-6 form-group">
                                <label asp-for="SenderId">Sender</label>
                                <select asp-for="SenderId" class="form-control form-select" asp-items="ViewBag.Senders" required>
                                    <option value="">Select Sender</option>
                                </select>
                                <span asp-validation-for="SenderId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label asp-for="ReceiverId">Receiver</label>
                                <select asp-for="ReceiverId" class="form-control form-select" asp-items="ViewBag.Receivers" required>
                                    <option value="">Select Receiver</option>
                                </select>
                                <span asp-validation-for="ReceiverId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4 border-top pt-3 text-end">
                            <a asp-controller="Shipment" asp-action="Index" class="btn btn-light me-2">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-gradient-primary btn-lg">
                                <i class="mdi mdi-check-circle me-1"></i> Create Shipment
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Placeholder calculation for Shipping Rate based on weight
            $('.package-calc').on('input', function () {
                var weight = parseFloat($('#Weight').val()) || 0;
                var baseRate = 50.0; // Base rate
                var ratePerKg = 15.0;
                var totalRate = baseRate + (weight * ratePerKg);
                $('#ShippingRate').val(totalRate.toFixed(2));
            });
        });
    </script>
}
