@model Domain.Entities.TbShippment
@{
    ViewData["Title"] = "Shipment Details";
    var timeline = ViewBag.Timeline as List<dynamic>;
}

@section Styles {
    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
            list-style: none;
        }
        .timeline::before {
            content: '';
            position: absolute;
            left: 10px;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e9ecef;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 1.5rem;
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -24px;
            top: 5px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #b66dff; /* Primary purple gradient color */
        }
        .timeline-date {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 0.2rem;
        }
        .timeline-content {
            background: #f8f9fa;
            padding: 10px 15px;
            border-radius: 4px;
            border: 1px solid #e9ecef;
        }
    </style>
}

<div class="content-wrapper">
    <div class="page-header">
        <h3 class="page-title"> Shipment Tracking: #@Model.TrackingNumber </h3>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-controller="Shipment" asp-action="Index">Shipments</a></li>
                <li class="breadcrumb-item active" aria-current="page">Details</li>
            </ol>
        </nav>
    </div>

    <div class="row">
        <!-- Main Shipment Info -->
        <div class="col-md-8 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4 border-bottom pb-2">
                        <i class="mdi mdi-information-outline me-2"></i>Shipment Overview
                    </h4>
                    
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <span class="d-block text-muted small">Tracking Number</span>
                            <span class="font-weight-bold" style="font-size: 1.1rem;">#@Model.TrackingNumber</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <span class="d-block text-muted small">Date Created</span>
                            <span class="font-weight-bold">@Model.ShippingDate.ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <span class="d-block text-muted small">Service Type</span>
                            <span class="badge badge-gradient-info">@(Model.ShippingType?.ShippingTypeEname ?? "Standard")</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <span class="d-block text-muted small">Status</span>
                            @if (Model.CurrentState == enEntityState.Active)
                            {
                                <span class="badge badge-gradient-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-gradient-warning">Inactive</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-4 bg-light p-3 rounded mx-0">
                        <div class="col-md-6 border-end">
                            <h5 class="font-weight-bold mb-3"><i class="mdi mdi-upload me-2 text-primary"></i>From (Sender)</h5>
                            <p class="mb-1 font-weight-bold">@(Model.Sender?.SenderName ?? "N/A")</p>
                            <p class="mb-1 text-muted small"><i class="mdi mdi-phone me-1"></i>@(Model.Sender?.Phone ?? "N/A")</p>
                            <p class="mb-0 text-muted small"><i class="mdi mdi-map-marker me-1"></i>Sender Address Info...</p>
                        </div>
                        <div class="col-md-6 pl-md-4">
                            <h5 class="font-weight-bold mb-3"><i class="mdi mdi-download me-2 text-info"></i>To (Receiver)</h5>
                            <p class="mb-1 font-weight-bold">@(Model.Receiver?.ReceiverName ?? "N/A")</p>
                            <p class="mb-1 text-muted small"><i class="mdi mdi-phone me-1"></i>@(Model.Receiver?.Phone ?? "N/A")</p>
                            <p class="mb-0 text-muted small"><i class="mdi mdi-map-marker me-1"></i>@(Model.Receiver?.Address ?? "N/A")</p>
                        </div>
                    </div>

                    <h4 class="card-title text-primary mb-3 border-bottom pb-2">
                        <i class="mdi mdi-package-variant-closed me-2"></i>Package Details
                    </h4>
                    <div class="row">
                        <div class="col-sm-3 mb-3">
                            <span class="d-block text-muted small">Weight</span>
                            <span class="font-weight-bold">@Model.Weight kg</span>
                        </div>
                        <div class="col-sm-3 mb-3">
                            <span class="d-block text-muted small">Dimensions</span>
                            <span class="font-weight-bold">@Model.Length x @Model.Width x @Model.Height cm</span>
                        </div>
                        <div class="col-sm-3 mb-3">
                            <span class="d-block text-muted small">Declared Value</span>
                            <span class="font-weight-bold">@Model.PackageValue.ToString("C")</span>
                        </div>
                        <div class="col-sm-3 mb-3">
                            <span class="d-block text-muted small">Shipping Rate</span>
                            <span class="font-weight-bold text-success">@Model.ShippingRate.ToString("C")</span>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a asp-controller="Shipment" asp-action="Index" class="btn btn-light btn-fw">Back to Shipments</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Timeline / Status Updates -->
        <div class="col-md-4 grid-margin stretch-card">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title text-primary mb-4 border-bottom pb-2">
                        <i class="mdi mdi-timeline me-2"></i>Tracking History
                    </h4>
                    
                    @if (timeline != null && timeline.Any())
                    {
                        <ul class="timeline">
                            @foreach (var step in timeline)
                            {
                                <li class="timeline-item">
                                    <div class="timeline-date">@step.Date.ToString("MMM dd, yyyy - HH:mm")</div>
                                    <div class="timeline-content">
                                        <h6 class="font-weight-bold mb-1">@step.Status</h6>
                                        <p class="text-muted small mb-0">@step.Notes</p>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="mdi mdi-clock-outline display-4 d-block mb-2"></i>
                            <p>No tracking history available yet.</p>
                        </div>
                    }

                    <div class="mt-4 pt-3 border-top text-center">
                        <button type="button" class="btn btn-gradient-info btn-sm btn-block w-100">
                            <i class="mdi mdi-plus-circle me-1"></i> Add Status Update
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
