@model UI.Models.Shipment.CreateShipmentViewModel

@{
    ViewData["Title"] = "Create Shipment";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create New Shipment</h4>
        </div>
        <div class="card-body">
            <form asp-action="CreateShipment" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <!-- Sender Information -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-info h-100">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0">Sender Details</h5>
                            </div>
                            <div class="card-body">
                                <input type="hidden" asp-for="Sender.ExistingId" />
                                
                                <div class="mb-3">
                                    <label asp-for="Sender.Name" class="form-label">Name</label>
                                    <input asp-for="Sender.Name" class="form-control" />
                                    <span asp-validation-for="Sender.Name" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.Email" class="form-label">Email</label>
                                    <input asp-for="Sender.Email" class="form-control" />
                                    <span asp-validation-for="Sender.Email" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.Phone" class="form-label">Phone</label>
                                    <input asp-for="Sender.Phone" class="form-control" />
                                    <span asp-validation-for="Sender.Phone" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.CityId" class="form-label">City</label>
                                    <select asp-for="Sender.CityId" asp-items="Model.Cities" class="form-select">
                                        <option value="">-- Select City --</option>
                                    </select>
                                    <span asp-validation-for="Sender.CityId" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.Address" class="form-label">Address</label>
                                    <input asp-for="Sender.Address" class="form-control" />
                                    <span asp-validation-for="Sender.Address" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.OtherAddress" class="form-label">Other Address</label>
                                    <input asp-for="Sender.OtherAddress" class="form-control" />
                                    <span asp-validation-for="Sender.OtherAddress" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.PostalCode" class="form-label">Postal Code</label>
                                    <input asp-for="Sender.PostalCode" class="form-control" />
                                    <span asp-validation-for="Sender.PostalCode" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Sender.Contact" class="form-label">Contact</label>
                                    <input asp-for="Sender.Contact" class="form-control" />
                                    <span asp-validation-for="Sender.Contact" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Receiver Information -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-success h-100">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0">Receiver Details</h5>
                            </div>
                            <div class="card-body">
                                <input type="hidden" asp-for="Receiver.ExistingId" />
                                
                                <div class="mb-3">
                                    <label asp-for="Receiver.Name" class="form-label">Name</label>
                                    <input asp-for="Receiver.Name" class="form-control" />
                                    <span asp-validation-for="Receiver.Name" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.Email" class="form-label">Email</label>
                                    <input asp-for="Receiver.Email" class="form-control" />
                                    <span asp-validation-for="Receiver.Email" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.Phone" class="form-label">Phone</label>
                                    <input asp-for="Receiver.Phone" class="form-control" />
                                    <span asp-validation-for="Receiver.Phone" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.CityId" class="form-label">City</label>
                                    <select asp-for="Receiver.CityId" asp-items="Model.Cities" class="form-select">
                                        <option value="">-- Select City --</option>
                                    </select>
                                    <span asp-validation-for="Receiver.CityId" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.Address" class="form-label">Address</label>
                                    <input asp-for="Receiver.Address" class="form-control" />
                                    <span asp-validation-for="Receiver.Address" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.OtherAddress" class="form-label">Other Address</label>
                                    <input asp-for="Receiver.OtherAddress" class="form-control" />
                                    <span asp-validation-for="Receiver.OtherAddress" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.PostalCode" class="form-label">Postal Code</label>
                                    <input asp-for="Receiver.PostalCode" class="form-control" />
                                    <span asp-validation-for="Receiver.PostalCode" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label asp-for="Receiver.Contact" class="form-label">Contact</label>
                                    <input asp-for="Receiver.Contact" class="form-control" />
                                    <span asp-validation-for="Receiver.Contact" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Shipment Information -->
                <div class="card border-warning mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0">Shipment Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Weight" class="form-label">Weight</label>
                                <input asp-for="Weight" class="form-control" />
                                <span asp-validation-for="Weight" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Length" class="form-label">Length</label>
                                <input asp-for="Length" class="form-control" />
                                <span asp-validation-for="Length" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Width" class="form-label">Width</label>
                                <input asp-for="Width" class="form-control" />
                                <span asp-validation-for="Width" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Height" class="form-label">Height</label>
                                <input asp-for="Height" class="form-control" />
                                <span asp-validation-for="Height" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="PackageValue" class="form-label">Package Value</label>
                                <input asp-for="PackageValue" class="form-control" />
                                <span asp-validation-for="PackageValue" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingDate" class="form-label">Shipping Date</label>
                                <input asp-for="ShippingDate" class="form-control" />
                                <span asp-validation-for="ShippingDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingTypeId" class="form-label">Shipping Type</label>
                                <select asp-for="ShippingTypeId" asp-items="Model.ShippingTypes" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="ShippingTypeId" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingPackagingId" class="form-label">Packaging Type</label>
                                <select asp-for="ShippingPackagingId" asp-items="Model.PackagingTypes" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="ShippingPackagingId" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="PaymentMethodId" class="form-label">Payment Method</label>
                                <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="PaymentMethodId" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <input type="hidden" asp-for="UserSubscriptionId" />
                    </div>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Submit Shipment</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
